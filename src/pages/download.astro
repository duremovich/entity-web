---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Download — entity"
  description="Download entity media server."
>
  <section class="download">
    <div class="download__inner">
      <p class="eyebrow">Download</p>
      <h1>Not packaged yet.</h1>
      <p class="download__lede">
        entity hasn't shipped a signed binary release. The download page goes
        live with the first tagged release.
      </p>

      <div class="download__card">
        <h2>Build from source</h2>
        <p>
          In the meantime, you can build entity from the public source tree.
          Windows is supported today; macOS and Linux are on the roadmap.
        </p>
        <pre><code>{`git clone https://github.com/duremovich/Entity.git
cd Entity
cmake -B build -S . \\
  -DCMAKE_TOOLCHAIN_FILE=C:/vcpkg/scripts/buildsystems/vcpkg.cmake
cmake --build build --config Release`}</code></pre>
        <p>
          Full instructions: <a href="/docs/getting-started/install/">install
          guide</a>.
        </p>
      </div>

      <div class="download__notify">
        <h2>Want a heads-up when v1 lands?</h2>
        <p>
          Watch the repo on GitHub — releases land there first.
        </p>
        <a
          href="https://github.com/duremovich/Entity"
          target="_blank"
          rel="noopener noreferrer"
          class="btn"
        >
          github.com/duremovich/Entity ↗
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .download {
    padding: 96px 32px 64px;
  }
  .download__inner {
    max-width: 920px;
    margin: 0 auto;
  }
  .download h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 12px 0 24px;
  }
  .download__lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin: 0 0 48px;
    max-width: 56ch;
  }
  .download__card,
  .download__notify {
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--color-line);
    background: rgba(255, 255, 255, 0.02);
    margin-bottom: 24px;
  }
  .download__card h2,
  .download__notify h2 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }
  .download__card p,
  .download__notify p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin: 0 0 16px;
  }
  .download__card a {
    color: var(--color-accent);
  }
  pre {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    font-family: var(--font-mono);
    margin: 16px 0;
  }
  code {
    color: var(--color-body-to);
  }
  .btn {
    display: inline-flex;
    padding: 12px 24px;
    border-radius: 8px;
    background: var(--color-accent);
    color: #1a0928;
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    font-family: var(--font-mono);
  }
  .btn:hover {
    background: #ff8c45;
  }
</style>
