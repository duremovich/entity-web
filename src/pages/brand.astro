---
import Layout from '../components/Layout.astro';

const colors = [
  { token: 'canvas', hex: '#1f0a35', use: 'page / canvas background' },
  { token: 'plate', hex: '#3a1a5a', use: 'mark plate inside the rim' },
  { token: 'body (from)', hex: '#41b261', use: 'wordmark + body pixels (start)' },
  { token: 'body (to)', hex: '#5dff8a', use: 'wordmark + body pixels (end)' },
  { token: 'stroke', hex: '#3ca65a', use: 'per-pixel cell stroke' },
  { token: 'whites (from)', hex: '#a8ffc4', use: 'eye whites (start)' },
  { token: 'whites (to)', hex: '#dfffe9', use: 'eye whites (end)' },
  { token: 'iris (from)', hex: '#ff3d0a', use: 'iris (start)' },
  { token: 'iris (to)', hex: '#ffd86b', use: 'iris (end)' },
  { token: 'accent', hex: '#ff7a2e', use: '"media server" / accent text' },
];

const lockups = [
  { src: '/brand/svg/mark.svg', label: 'Primary mark' },
  { src: '/brand/svg/mark-square.svg', label: 'Mark — square (app icon)' },
  { src: '/brand/svg/lockup-horizontal.svg', label: 'Horizontal lockup' },
  { src: '/brand/svg/lockup-stacked.svg', label: 'Stacked lockup' },
  { src: '/brand/svg/lockup-vertical.svg', label: 'Vertical lockup' },
  { src: '/brand/svg/wordmark-with-tagline.svg', label: 'Wordmark + tagline' },
  { src: '/brand/svg/wordmark.svg', label: 'Wordmark only' },
];
---

<Layout
  title="Brand — entity"
  description="entity brand assets — logos, colors, type."
>
  <section class="brand">
    <div class="brand__inner">
      <p class="eyebrow">Brand</p>
      <h1>entity — visual identity</h1>
      <p class="brand__lede">
        Pixel-grid creature mark + lowercase wordmark. Designed for screens,
        prints, and projections. Use for editorial coverage, community
        events, and integrations.
      </p>

      <h2>Primary mark</h2>
      <div class="brand__hero">
        <img src="/brand/svg/mark.svg" alt="entity mark" />
      </div>

      <h2>Lockups</h2>
      <div class="brand__grid">
        {
          lockups.map((l) => (
            <div class="brand__card">
              <div class="brand__art">
                <img src={l.src} alt={l.label} />
              </div>
              <div class="brand__label">{l.label}</div>
            </div>
          ))
        }
      </div>

      <h2>Colors</h2>
      <table class="brand__colors">
        <thead>
          <tr>
            <th>Token</th>
            <th>Swatch</th>
            <th>Hex</th>
            <th>Use</th>
          </tr>
        </thead>
        <tbody>
          {
            colors.map((c) => (
              <tr>
                <td>{c.token}</td>
                <td>
                  <div class="brand__swatch" style={`background: ${c.hex};`} />
                </td>
                <td class="brand__hex">{c.hex}</td>
                <td>{c.use}</td>
              </tr>
            ))
          }
        </tbody>
      </table>

      <h2>Typography</h2>
      <div class="brand__type">
        <div class="brand__type-card">
          <div class="brand__sample brand__sample--display">entity</div>
          <div class="brand__type-meta">
            Space Grotesk SemiBold (600) · lowercase · −3% letter-spacing
          </div>
        </div>
        <div class="brand__type-card">
          <div class="brand__sample brand__sample--accent">media server</div>
          <div class="brand__type-meta">
            Space Grotesk Medium (500) · UPPERCASE · +30% tracking
          </div>
        </div>
      </div>

      <h2>Downloads</h2>
      <p>
        Asset source lives in the engine repo at
        <a
          href="https://github.com/duremovich/Entity/tree/master/images"
          target="_blank"
          rel="noopener noreferrer"
        ><code>/images</code></a>. SVGs are self-contained (text converted to
        paths) and render without Space Grotesk installed.
      </p>
    </div>
  </section>
</Layout>

<style>
  .brand {
    padding: 96px 32px 64px;
  }
  .brand__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .brand h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 12px 0 24px;
  }
  .brand__lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    max-width: 60ch;
    margin: 0 0 64px;
  }
  .brand h2 {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 80px 0 24px;
  }
  .brand__hero {
    background: var(--color-canvas);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    padding: 64px;
    display: flex;
    justify-content: center;
  }
  .brand__hero img {
    width: 280px;
    height: 280px;
  }
  .brand__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }
  .brand__card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }
  .brand__art {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .brand__art img {
    max-height: 120px;
    max-width: 100%;
  }
  .brand__label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .brand__colors {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .brand__colors th,
  .brand__colors td {
    text-align: left;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-line);
  }
  .brand__colors th {
    color: var(--color-ink-dim);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .brand__swatch {
    width: 80px;
    height: 24px;
    border-radius: 6px;
    border: 1px solid var(--color-line);
  }
  .brand__hex {
    font-family: var(--font-mono);
    color: var(--color-ink-dim);
  }
  .brand__type {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .brand__type-card {
    padding: 48px;
    border-radius: 12px;
    border: 1px solid var(--color-line);
    background: rgba(255, 255, 255, 0.02);
  }
  .brand__sample--display {
    font-size: 96px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    background: linear-gradient(135deg, #41b261, #5dff8a);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .brand__sample--accent {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .brand__type-meta {
    color: var(--color-ink-dim);
    font-size: 13px;
    font-family: var(--font-mono);
    margin-top: 16px;
  }
  code {
    background: rgba(0, 0, 0, 0.4);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: var(--font-mono);
  }
  a {
    color: var(--color-accent);
  }
  @media (max-width: 720px) {
    .brand__type {
      grid-template-columns: 1fr;
    }
    .brand__sample--display {
      font-size: 64px;
    }
  }
</style>
