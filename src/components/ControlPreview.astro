---
// Show-control section: two-way positioning, a live OSC terminal demo, and
// a protocol strip showing what ships today vs. what's on the roadmap.
const protocols = [
  {
    name: 'OSC',
    status: 'live',
    statusLabel: 'Live today',
    body: 'Cue entity from any OSC source, and stream its transport and section state back out.',
  },
  {
    name: 'MIDI Show Control',
    status: 'roadmap',
    statusLabel: 'On the roadmap',
    body: 'Take MSC cue pings to advance the timeline, or call cues out to lighting consoles and QLab.',
  },
  {
    name: 'LTC / SMPTE timecode',
    status: 'roadmap',
    statusLabel: 'On the roadmap',
    body: 'Chase an external clock so playback stays locked to the rest of the show.',
  },
  {
    name: 'DMX (Art-Net / sACN)',
    status: 'roadmap',
    statusLabel: 'On the roadmap',
    body: "Drive fixtures from control layers, or let a lighting desk drive entity's parameters.",
  },
];
---

<section class="ctrl">
  <div class="ctrl__inner">
    <div class="ctrl__main">
      <div class="ctrl__copy">
        <p class="eyebrow">Show control</p>
        <h2>Takes cues. Gives cues.</h2>
        <p>
          A show is a chain of gear taking cues off each other. entity sits in
          that chain as a full member — it advances its own timeline off cues
          from the stage manager's desk, and it calls cues back out to
          everything else in the rig.
        </p>
        <p>
          Today that's OSC, both directions. A Stream Deck button sends a cue,
          entity hears it and fires the section — and entity broadcasts its own
          transport and section state back out for the rest of the rig to
          follow. No middleware. Pair it with <a
            href="https://bitfocus.io/companion"
            target="_blank"
            rel="noopener noreferrer"
          >Bitfocus Companion</a> and you inherit hundreds of show-hardware
          modules.
        </p>
        <a href="/docs/control/" class="link-arrow ctrl__link">Show control docs →</a>
      </div>

      <div class="ctrl__term">
        <div class="ctrl__term-bar">
          <span class="ctrl__term-dot ctrl__term-dot--r"></span>
          <span class="ctrl__term-dot ctrl__term-dot--y"></span>
          <span class="ctrl__term-dot ctrl__term-dot--g"></span>
          <span class="ctrl__term-title">
            udp 127.0.0.1:53000 — entity receiver
          </span>
        </div>
        <pre class="ctrl__term-body"><code><span class="c">{`# Start the show`}</span>
<span class="o">/entity/play</span>

<span class="c">{`# Cue 5 — top of Act II`}</span>
<span class="o">/entity/cue/5/go</span>

<span class="c">{`# Drop into the interlude`}</span>
<span class="o">/entity/section/next</span>

<span class="c">{`# Operator scrubs back during a hold`}</span>
<span class="o">/entity/seek</span> <span class="n">3600</span>

<span class="c">{`# Hold and reset`}</span>
<span class="o">/entity/pause</span>
<span class="o">/entity/stop</span></code></pre>
      </div>
    </div>

    <div class="ctrl__protocols">
      {
        protocols.map((p) => (
          <article class="ctrl__proto">
            <div class="ctrl__proto-head">
              <h3>{p.name}</h3>
              <span class={`ctrl__proto-tag ctrl__proto-tag--${p.status}`}>
                {p.statusLabel}
              </span>
            </div>
            <p>{p.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ctrl {
    padding: var(--section-pad-y) var(--page-pad-x);
  }
  .ctrl__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .ctrl__main {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
    align-items: center;
  }
  .ctrl__copy h2 {
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 12px 0 24px;
    max-width: 14ch;
  }
  .ctrl__copy p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin: 0 0 16px;
    max-width: 44ch;
  }
  .ctrl__copy a {
    color: var(--color-accent);
  }
  .ctrl__link {
    display: inline-block;
    margin-top: 24px;
  }
  .ctrl__term {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    background: #110620;
  }
  .ctrl__term-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-line);
  }
  .ctrl__term-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }
  .ctrl__term-dot--r { background: #ff5f56; }
  .ctrl__term-dot--y { background: #ffbd2e; }
  .ctrl__term-dot--g { background: #27c93f; }
  .ctrl__term-title {
    margin-left: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-dim);
  }
  .ctrl__term-body {
    margin: 0;
    padding: 28px 28px 32px;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.8;
    color: var(--color-ink);
    overflow-x: auto;
  }
  .ctrl__term-body code {
    background: transparent;
    padding: 0;
  }
  .ctrl__term-body .c { color: rgba(255, 255, 255, 0.4); }
  .ctrl__term-body .o { color: #5dff8a; font-weight: 500; }
  .ctrl__term-body .n { color: #ff7a2e; }

  .ctrl__protocols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 56px;
  }
  .ctrl__proto {
    padding: 22px;
    border-radius: 12px;
    border: 1px solid var(--color-line);
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ctrl__proto-head {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ctrl__proto h3 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
  }
  .ctrl__proto-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .ctrl__proto-tag--live { color: #5dff8a; }
  .ctrl__proto-tag--roadmap { color: var(--color-ink-dim); }
  .ctrl__proto p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin: 0;
  }

  @media (max-width: 960px) {
    .ctrl__main {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .ctrl__protocols {
      grid-template-columns: repeat(2, 1fr);
      margin-top: 40px;
    }
  }
  @media (max-width: 560px) {
    .ctrl__protocols {
      grid-template-columns: 1fr;
    }
  }
</style>
