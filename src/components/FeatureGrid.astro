---
import SectionIntro from './SectionIntro.astro';

const features = [
  {
    title: 'Real-time decode',
    body:
      'Every clip runs its own lock-free decode pipeline, so many video streams play and scrub at once without stutter. Frame-accurate seeking, no global decode lock.',
  },
  {
    title: 'Professional codecs',
    body:
      'ProRes 4444 (with alpha), HAP, PNG sequences. Mixed frame rates handled natively — drop a 24fps clip on a 60fps timeline and it plays at its own rate.',
  },
  {
    title: 'Projection mapping',
    body:
      'Anchor-point calibration with a lens model. Soft-edge blending across multi-projector arrays. Persistent display identification by EDID.',
  },
  {
    title: 'Show-grade timing',
    body:
      'A dedicated show thread owns GPU compositing and output present. Editor modals, file dialogs, and resize loops never freeze the projectors.',
  },
  {
    title: 'OSC control',
    body:
      'Inbound OSC over UDP. Play, pause, seek, fire sections, jump to cues. Pairs natively with Bitfocus Companion for the rest of show control.',
  },
  {
    title: 'Projects travel',
    body:
      'A project is a folder. Copy it to a USB stick, sync to another machine, hand it to a collaborator — media, timeline, calibration, and settings move together as one tree.',
  },
  {
    title: 'Layered timeline',
    body:
      'Three layer kinds on one timeline: clip layers, object-animation layers that keyframe-drive screen and prop transforms, generative layers for procedural content. All composited through the same path.',
  },
  {
    title: 'Per-layer effects',
    body:
      'An ordered shader chain on every layer. Nine engine effects ship today — Gaussian blur, sharpen, vignette, pixelate, chromatic aberration, edge detect, brightness/contrast, hue/saturation, invert. Author your own as HLSL effect packs.',
  },
  {
    title: 'Content routing + Feed Maps',
    body:
      'Route logical content to screens independently of how those screens reach physical outputs. Tiled routes split a canvas across LED panels. Feed Maps name regions on a source canvas and export an SVG template content creators can author against.',
  },
];
---

<section class="features">
  <div class="features__inner">
    <SectionIntro
      eyebrow="What it does"
      heading="Designed around the live-show contract"
      lede="Most media servers were built to make pretty things in software. entity was built around one rule: when the curtain goes up, the projectors must keep playing — even when the operator hits an OS dialog, plugs in a display, or scrubs the timeline mid-cue."
    />

    <div class="features__grid">
      {
        features.map((f) => (
          <article class="feature">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--section-pad-y) var(--page-pad-x);
  }
  .features__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .feature {
    padding: 28px;
    border-radius: 12px;
    border: 1px solid var(--color-line);
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .feature:hover {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.035);
  }
  .feature h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .feature p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin: 0;
  }
  @media (max-width: 960px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
