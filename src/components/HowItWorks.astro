---
const steps = [
  {
    n: '01',
    title: 'Drop media in',
    body:
      'Your project is a folder. Paste ProRes, HAP, or PNG sequences into content/ — even while the editor is running. The content scanner picks them up within a frame.',
    foot: 'No re-import step. No "where did my media go" after copying a project to a new machine.',
  },
  {
    n: '02',
    title: 'Place on the timeline',
    body:
      'Drag clips onto tracks. Set screen targets. Mark section break-points. Animate opacity / transform with keyframes. Mix frame rates without retiming.',
    foot: 'Timeline runs at a fixed rate. Each clip plays at its own native rate, mapped on top.',
  },
  {
    n: '03',
    title: 'Send and trigger',
    body:
      'Assign screens to physical outputs by EDID — stable across reboots and re-cabling. Calibrate projectors with anchor points. Fire sections from OSC, Companion, or a scripted run.',
    foot: 'Editor stalls (modal dialogs, resizes, slow loads) never stop the projector output.',
  },
];
---

<section class="how">
  <div class="how__inner">
    <p class="eyebrow">How it works</p>
    <h2>Three stages, no mystery.</h2>
    <p class="how__lede">
      A project goes from empty folder to playing show in three concrete
      moves. Each one is a separate file or document menu — nothing is
      hidden in a side-effect.
    </p>

    <ol class="how__steps">
      {
        steps.map((s) => (
          <li class="how__step">
            <div class="how__n">{s.n}</div>
            <div class="how__body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
              <p class="how__foot">{s.foot}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how {
    padding: 96px 32px;
    background: linear-gradient(
      180deg,
      rgba(58, 26, 90, 0.18),
      rgba(31, 10, 53, 0)
    );
  }
  .how__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .how h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 12px 0 16px;
    max-width: 22ch;
  }
  .how__lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    max-width: 64ch;
    margin: 0 0 56px;
  }
  .how__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .how__step {
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--color-line);
    background: rgba(255, 255, 255, 0.02);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .how__n {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.2em;
  }
  .how__body h3 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
  }
  .how__body p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin: 0;
  }
  .how__foot {
    margin-top: 12px !important;
    padding-top: 16px;
    border-top: 1px solid var(--color-line);
    font-size: 13px !important;
    color: rgba(255, 255, 255, 0.4) !important;
    font-style: italic;
  }
  @media (max-width: 960px) {
    .how__steps {
      grid-template-columns: 1fr;
    }
  }
</style>
