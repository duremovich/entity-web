---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__col">
      <img
        src="/brand/svg/wordmark-transparent.svg"
        alt="entity"
        class="site-footer__lockup"
      />
      <p>media server for projection mapping. open-core. built for live shows.</p>
    </div>

    <div class="site-footer__col">
      <h4>Project</h4>
      <ul>
        <li><a href="/docs/">Docs</a></li>
        <li><a href="/download/">Download</a></li>
        <li><a href="/community/">Community</a></li>
        <li><a href="/docs/roadmap/">Roadmap</a></li>
        <li><a href="/docs/faq/">FAQ</a></li>
      </ul>
    </div>

    <div class="site-footer__col">
      <h4>Code</h4>
      <ul>
        <li>
          <a href="https://github.com/duremovich/Entity" target="_blank" rel="noopener">
            GitHub
          </a>
        </li>
        <li>
          <a
            href="https://github.com/duremovich/Entity/discussions"
            target="_blank"
            rel="noopener"
          >
            Discussions
          </a>
        </li>
        <li>
          <a
            href="https://github.com/duremovich/Entity/blob/master/LICENSING.md"
            target="_blank"
            rel="noopener"
          >
            License
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="site-footer__legal">
    <span>© {year} entity</span>
    <span class="dim">core: GPLv3</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-line);
    margin-top: 120px;
    padding: 64px 32px 40px;
  }
  .site-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
  }
  .site-footer__lockup {
    height: 32px;
    width: auto;
    margin-bottom: 16px;
  }
  .site-footer__col p {
    color: var(--color-ink-dim);
    font-size: 14px;
    line-height: 1.6;
    max-width: 38ch;
    margin: 0;
  }
  .site-footer__col h4 {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 16px;
  }
  .site-footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .site-footer__col a {
    color: var(--color-ink-dim);
    text-decoration: none;
    font-size: 14px;
  }
  .site-footer__col a:hover,
  .site-footer__col a:focus-visible {
    color: var(--color-ink);
  }
  .site-footer__legal {
    max-width: 1280px;
    margin: 48px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--color-line);
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--color-ink-dim);
    letter-spacing: 0.05em;
  }
  .site-footer__legal .dim {
    font-family: var(--font-mono);
  }
  @media (max-width: 720px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .site-footer__legal {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
