{
  // Static-assets-only Worker — publishes the Astro build output in dist/.
  // No Worker script ("main" omitted); Cloudflare serves dist/ directly
  // from its edge. Build command `npm run build` produces dist/; deploy
  // command `npx wrangler deploy` uploads it.
  "name": "entity-web",
  "compatibility_date": "2026-05-21",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
